{%- comment -%}
  Renders a dynamic product mockup SVG.
  Accepts:
  - category: {String} 'Tees' | 'Hoodies' | 'Shorts' | 'Lowers' (default: 'Tees')
  - series: {String} 'Social Battery Series' | 'Memory Corruption Series' | 'Dreamstate Division' | 'Human Error Series' | 'Instinct Protocol'
  - emotion: {String} 'Chaos' | 'Isolation' | 'Obsession' | 'Escape' | 'Overthinking' | 'Burnout'
  - class_name: {String} Custom CSS class
{%- endcomment -%}

{%- liquid
  assign mock_category = category | default: 'Tees'
  assign mock_series = series | default: 'Social Battery Series'
  assign mock_emotion = emotion | default: ''
  assign svg_class = class_name | default: ''

  # Determine color based on series
  if mock_series == 'Social Battery Series'
    assign color = '#FF2244'
  elsif mock_series == 'Memory Corruption Series'
    assign color = '#0066CC'
  elsif mock_series == 'Dreamstate Division'
    assign color = '#9B7EDE'
  elsif mock_series == 'Human Error Series'
    assign color = '#7B2FBE'
  elsif mock_series == 'Instinct Protocol'
    assign color = '#CCFF00'
  else
    assign color = '#CCFF00'
  endif

  # Determine silhouette path
  if mock_category == 'Tees'
    assign silhouette = 'M35,28 L65,28 L72,32 L78,48 L72,52 L68,48 L68,88 L32,88 L32,48 L28,52 L22,48 L28,32 Z'
  elsif mock_category == 'Hoodies'
    assign silhouette = 'M32,22 L68,22 L76,28 L82,52 L74,56 L70,50 L70,92 L30,92 L30,50 L26,56 L18,52 L24,28 Z M38,22 C38,14 42,10 50,10 C58,10 62,14 62,22'
  elsif mock_category == 'Shorts'
    assign silhouette = 'M32,28 L68,28 L72,32 L74,58 L52,58 L50,48 L48,58 L26,58 L28,32 Z'
  elsif mock_category == 'Lowers'
    assign silhouette = 'M34,22 L66,22 L70,26 L72,42 L68,46 L68,92 L54,92 L52,56 L50,56 L48,92 L34,92 L34,46 L30,42 L32,26 Z'
  else
    assign silhouette = 'M35,28 L65,28 L72,32 L78,48 L72,52 L68,48 L68,88 L32,88 L32,48 L28,52 L22,48 L28,32 Z'
  endif
-%}

<svg
  viewBox="0 0 100 100"
  class="product-mockup-svg {{ svg_class }}"
  preserveAspectRatio="xMidYMid meet"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <!-- Dream blur filter -->
    <filter id="dreamBlur-{{ mock_category }}-{{ mock_emotion | handle }}">
      <feGaussianBlur stdDeviation="0.6" />
    </filter>
    <!-- Glow filter for signal mode -->
    <filter id="signalGlow-{{ mock_category }}-{{ mock_emotion | handle }}">
      <feGaussianBlur stdDeviation="1.2" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
    <!-- Background gradient -->
    <linearGradient id="bgGrad-{{ mock_category }}-{{ mock_emotion | handle }}" x1="0" y1="0" x2="100" y2="100">
      <stop offset="0%" stop-color="{{ color }}" stop-opacity="0.08" />
      <stop offset="100%" stop-color="{{ color }}" stop-opacity="0.01" />
    </linearGradient>
    <!-- Silhouette fill -->
    <linearGradient id="silGrad-{{ mock_category }}-{{ mock_emotion | handle }}" x1="0" y1="0" x2="0" y2="100">
      <stop offset="0%" stop-color="{{ color }}" stop-opacity="0.12" />
      <stop offset="100%" stop-color="{{ color }}" stop-opacity="0.03" />
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="100" height="100" fill="url(#bgGrad-{{ mock_category }}-{{ mock_emotion | handle }})" />

  <!-- Product silhouette -->
  <path
    d="{{ silhouette }}"
    fill="url(#silGrad-{{ mock_category }}-{{ mock_emotion | handle }})"
    stroke="{{ color }}"
    stroke-width="0.6"
    opacity="0.3"
  />

  <!-- Series artwork overlaid -->
  <g class="series-art" filter="url(#signalGlow-{{ mock_category }}-{{ mock_emotion | handle }})">
    {%- if mock_series == 'Social Battery Series' -%}
      <!-- Glitch lines -->
      <line x1="22" y1="38" x2="74" y2="38" stroke="{{ color }}" stroke-width="0.8" opacity="0.5" />
      <line x1="20" y1="44" x2="80" y2="44" stroke="{{ color }}" stroke-width="1.2" opacity="0.6" />
      <line x1="28" y1="50" x2="68" y2="50" stroke="{{ color }}" stroke-width="0.8" opacity="0.4" />
      <line x1="24" y1="56" x2="72" y2="56" stroke="{{ color }}" stroke-width="1.4" opacity="0.7" />
      <line x1="22" y1="62" x2="78" y2="62" stroke="{{ color }}" stroke-width="0.9" opacity="0.5" />
      <line x1="20" y1="68" x2="70" y2="68" stroke="{{ color }}" stroke-width="1.0" opacity="0.4" />
      <!-- Battery outline -->
      <rect x="38" y="36" width="24" height="12" rx="1" fill="none" stroke="{{ color }}" stroke-width="1.5" opacity="0.8" />
      <rect x="62" y="39" width="3" height="6" rx="0.5" fill="{{ color }}" opacity="0.6" />
      <!-- Battery status bars -->
      <rect x="40" y="38" width="4" height="8" rx="0.5" fill="{{ color }}" opacity="0.9" />
      <rect x="46" y="38" width="4" height="8" rx="0.5" fill="{{ color }}" opacity="0.15" />
      <rect x="52" y="38" width="4" height="8" rx="0.5" fill="{{ color }}" opacity="0.15" />
      <rect x="58" y="38" width="4" height="8" rx="0.5" fill="{{ color }}" opacity="0.15" />
      <!-- Signal diagnostic bars -->
      <rect x="72" y="56" width="2.5" height="14" rx="0.5" fill="{{ color }}" opacity="0.3" />
      <rect x="76" y="52" width="2.5" height="18" rx="0.5" fill="{{ color }}" opacity="0.45" />
      <rect x="80" y="48" width="2.5" height="22" rx="0.5" fill="{{ color }}" opacity="0.6" />
      <rect x="84" y="44" width="2.5" height="26" rx="0.5" fill="{{ color }}" opacity="0.75" />
      <!-- Monospace diagnostics text -->
      <text x="24" y="78" fill="{{ color }}" font-size="4" font-family="monospace" opacity="0.5" letter-spacing="0.1em">SYS.DIAG // BATTERY_CRITICAL</text>
      <text x="24" y="84" fill="{{ color }}" font-size="3.5" font-family="monospace" opacity="0.35" letter-spacing="0.08em">RECHARGE_FAILED // SIGNAL_LOST</text>

    {%- elsif mock_series == 'Memory Corruption Series' -%}
      <!-- VHS tracking scanlines -->
      <line x1="15" y1="35" x2="85" y2="35" stroke="{{ color }}" stroke-width="0.4" opacity="0.1" />
      <line x1="15" y1="42" x2="85" y2="42" stroke="{{ color }}" stroke-width="0.4" opacity="0.15" />
      <line x1="15" y1="49" x2="85" y2="49" stroke="{{ color }}" stroke-width="0.4" opacity="0.08" />
      <line x1="15" y1="56" x2="85" y2="56" stroke="{{ color }}" stroke-width="0.4" opacity="0.12" />
      <line x1="15" y1="63" x2="85" y2="63" stroke="{{ color }}" stroke-width="0.4" opacity="0.18" />
      <line x1="15" y1="70" x2="85" y2="70" stroke="{{ color }}" stroke-width="0.4" opacity="0.1" />
      <line x1="15" y1="77" x2="85" y2="77" stroke="{{ color }}" stroke-width="0.4" opacity="0.14" />
      <!-- Distortion horizontal blocks -->
      <rect x="22" y="36" width="18" height="4" fill="{{ color }}" opacity="0.15" />
      <rect x="58" y="44" width="14" height="3" fill="{{ color }}" opacity="0.2" />
      <rect x="30" y="56" width="22" height="5" fill="{{ color }}" opacity="0.16" />
      <rect x="48" y="68" width="16" height="3" fill="{{ color }}" opacity="0.22" />
      <rect x="24" y="78" width="20" height="4" fill="{{ color }}" opacity="0.12" />
      <!-- Corruption erosion pixels -->
      <rect x="28" y="40" width="3" height="3" fill="{{ color }}" opacity="0.3" />
      <rect x="66" y="52" width="2.5" height="2.5" fill="{{ color }}" opacity="0.35" />
      <rect x="34" y="64" width="4" height="4" fill="{{ color }}" opacity="0.25" />
      <rect x="60" y="72" width="2" height="2" fill="{{ color }}" opacity="0.4" />
      <!-- Face layout abstract -->
      <ellipse cx="50" cy="52" rx="14" ry="18" fill="none" stroke="{{ color }}" stroke-width="0.6" opacity="0.25" stroke-dasharray="3 2" />
      <ellipse cx="50" cy="52" rx="10" ry="14" fill="none" stroke="{{ color }}" stroke-width="0.4" opacity="0.15" />
      <!-- Text labels -->
      <text x="24" y="86" fill="{{ color }}" font-size="3.5" font-family="monospace" opacity="0.4" letter-spacing="0.12em">ARCHIVE_DEGRADED // FILE_NOT_FOUND</text>
      <text x="24" y="90" fill="{{ color }}" font-size="3" font-family="monospace" opacity="0.25" letter-spacing="0.1em">MEMORY_LEAK_DETECTED // IDENTITY_MISSING</text>

    {%- elsif mock_series == 'Dreamstate Division' -%}
      <!-- Cloud gradients -->
      <ellipse cx="35" cy="42" rx="16" ry="12" fill="{{ color }}" opacity="0.12" />
      <ellipse cx="65" cy="56" rx="14" ry="10" fill="{{ color }}" opacity="0.1" />
      <ellipse cx="45" cy="68" rx="12" ry="8" fill="{{ color }}" opacity="0.08" />
      <!-- Floating boxes -->
      <rect x="32" y="38" width="14" height="10" rx="1" fill="none" stroke="{{ color }}" stroke-width="0.5" opacity="0.3" />
      <rect x="54" y="50" width="12" height="8" rx="1" fill="none" stroke="{{ color }}" stroke-width="0.4" opacity="0.25" />
      <!-- Staircases lines -->
      <line x1="30" y1="72" x2="70" y2="72" stroke="{{ color }}" stroke-width="0.3" opacity="0.2" />
      <line x1="34" y1="68" x2="66" y2="68" stroke="{{ color }}" stroke-width="0.3" opacity="0.18" />
      <line x1="38" y1="64" x2="62" y2="64" stroke="{{ color }}" stroke-width="0.3" opacity="0.15" />
      <!-- Dreamstate portal rings -->
      <circle cx="50" cy="48" r="20" fill="none" stroke="{{ color }}" stroke-width="0.4" opacity="0.12" stroke-dasharray="4 3" />
      <circle cx="50" cy="48" r="14" fill="none" stroke="{{ color }}" stroke-width="0.3" opacity="0.1" />
      <!-- Blurred typography -->
      <text x="24" y="84" fill="{{ color }}" font-size="4" font-family="monospace" opacity="0.3" letter-spacing="0.15em" filter="url(#dreamBlur-{{ mock_category }}-{{ mock_emotion | handle }})">BETWEEN_DREAMS</text>
      <text x="24" y="89" fill="{{ color }}" font-size="3" font-family="monospace" opacity="0.2" letter-spacing="0.12em" filter="url(#dreamBlur-{{ mock_category }}-{{ mock_emotion | handle }})">ARTIFICIAL_REALITY // SLEEP_DIVISION</text>

    {%- elsif mock_series == 'Human Error Series' -%}
      <!-- Error popup alerts -->
      <rect x="28" y="32" width="44" height="18" rx="2" fill="none" stroke="{{ color }}" stroke-width="1" opacity="0.5" />
      <rect x="30" y="34" width="40" height="3" rx="0.5" fill="{{ color }}" opacity="0.25" />
      <text x="32" y="42" fill="{{ color }}" font-size="3.5" font-family="monospace" opacity="0.7" font-weight="bold">ERROR: EMOTION_OVERFLOW</text>
      <text x="32" y="47" fill="{{ color }}" font-size="3" font-family="monospace" opacity="0.45">System stability compromised.</text>
      <!-- Smaller window popup -->
      <rect x="48" y="54" width="30" height="14" rx="1.5" fill="none" stroke="{{ color }}" stroke-width="0.7" opacity="0.35" />
      <text x="50" y="60" fill="{{ color }}" font-size="2.8" font-family="monospace" opacity="0.5">WARNING: STABILITY</text>
      <text x="50" y="64" fill="{{ color }}" font-size="2.5" font-family="monospace" opacity="0.4">Reboot required.</text>
      <!-- Warning triangles -->
      <polygon points="24,70 28,78 20,78" fill="{{ color }}" opacity="0.3" />
      <polygon points="72,36 76,44 68,44" fill="{{ color }}" opacity="0.25" />
      <!-- Diagnostic footer -->
      <text x="24" y="92" fill="{{ color }}" font-size="2.8" font-family="monospace" opacity="0.35" letter-spacing="0.1em">HUMAN_ERROR_DETECTED // SYSTEM_FAILURE</text>

    {%- elsif mock_series == 'Instinct Protocol' -%}
      <!-- Concentric circles -->
      <circle cx="38" cy="44" r="10" fill="none" stroke="{{ color }}" stroke-width="0.8" opacity="0.4" />
      <circle cx="38" cy="44" r="6" fill="none" stroke="{{ color }}" stroke-width="0.5" opacity="0.3" />
      <circle cx="38" cy="44" r="2.5" fill="{{ color }}" opacity="0.5" />
      <!-- Crossed chaos symbols -->
      <line x1="58" y1="36" x2="72" y2="50" stroke="{{ color }}" stroke-width="0.7" opacity="0.35" />
      <line x1="72" y1="36" x2="58" y2="50" stroke="{{ color }}" stroke-width="0.7" opacity="0.35" />
      <circle cx="65" cy="43" r="3" fill="none" stroke="{{ color }}" stroke-width="0.5" opacity="0.3" />
      <!-- Silence rectangle motif -->
      <rect x="30" y="58" width="18" height="2" rx="0.5" fill="{{ color }}" opacity="0.25" />
      <rect x="34" y="62" width="10" height="1.5" rx="0.5" fill="{{ color }}" opacity="0.18" />
      <!-- Escape arrow path -->
      <line x1="56" y1="58" x2="70" y2="58" stroke="{{ color }}" stroke-width="0.6" opacity="0.3" />
      <polygon points="68,55 74,58 68,61" fill="{{ color }}" opacity="0.3" />
      <!-- System tags -->
      <text x="24" y="88" fill="{{ color }}" font-size="3.5" font-family="monospace" opacity="0.35" letter-spacing="0.15em">INSTINCT_PROTOCOL // SYMBOL_SYSTEM</text>
    {%- endif -%}
  </g>

  <!-- Emotion badge -->
  {%- if mock_emotion != blank -%}
    <g class="emotion-badge">
      <rect x="4" y="4" width="28" height="6" rx="1" fill="{{ color }}" opacity="0.15" />
      <text x="6" y="8.5" fill="{{ color }}" font-size="3.5" font-family="monospace" font-weight="bold" opacity="0.7" letter-spacing="0.08em">{{ mock_emotion | upcase }}</text>
    </g>
  {%- endif -%}

  <!-- Border corner accents -->
  <line x1="2" y1="96" x2="2" y2="88" stroke="{{ color }}" stroke-width="0.5" opacity="0.3" />
  <line x1="2" y1="96" x2="10" y2="96" stroke="{{ color }}" stroke-width="0.5" opacity="0.3" />
  <line x1="98" y1="4" x2="98" y2="12" stroke="{{ color }}" stroke-width="0.5" opacity="0.3" />
  <line x1="98" y1="4" x2="90" y2="4" stroke="{{ color }}" stroke-width="0.5" opacity="0.3" />
</svg>
