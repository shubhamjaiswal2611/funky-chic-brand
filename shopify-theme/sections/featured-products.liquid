{%- liquid
  assign featured_collection = collections[section.settings.collection]
  assign product_limit = section.settings.limit | default: 3
-%}

<section 
  data-ocid="home.featured_products_section"
  class="py-20"
  style="background-color: oklch(var(--card) / 0.3); border-top: 1px solid oklch(var(--border)); border-bottom: 1px solid oklch(var(--border));"
>
  <div class="container">
    <!-- Header -->
    <div class="mb-12">
      <p class="font-mono text-xs uppercase tracking-[0.2em] mb-3" style="color: oklch(var(--primary));">
        {{ section.settings.prefix_text }}
      </p>
      <h2 
        class="font-display font-black uppercase text-foreground"
        style="font-size: clamp(1.8rem, 5vw, 3rem); letter-spacing: -0.02em;"
      >
        {{ section.settings.title }}
      </h2>
    </div>

    <!-- Products grid loop -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
        {%- for product in featured_collection.products limit: product_limit -%}
          {% render 'product-card', product: product, index: forloop.index0 %}
        {%- endfor -%}
      {%- else -%}
        <!-- Mock cards if collection empty to ensure visual representation -->
        {%- for i in (1..3) -%}
          <div class="card-brand flex flex-col" style="animation-delay: {{ i | multiply: 0.08 }}s;">
            <div class="relative w-full overflow-hidden" style="aspect-ratio: 3/4; background-color: oklch(var(--muted) / 0.15);">
              <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background-color: oklch(var(--card));">
                {% comment %} Draw generic mockup SVG {% endcomment %}
                {% render 'product-mockup', category: 'Tees', series: 'Social Battery Series', emotion: 'Obsession' %}
              </div>
              <div class="price-badge absolute top-3 right-3 rounded px-2.5 py-1 font-display text-sm font-bold" style="background-color: oklch(var(--background)); border: 1px solid oklch(var(--border));">
                Rs.2,499
              </div>
            </div>
            <div class="p-4 flex flex-col flex-1" style="border-top: 1px solid oklch(var(--border));">
              <p class="text-[9px] font-semibold uppercase tracking-[0.2em] mb-1.5" style="color: oklch(var(--muted-foreground));">
                Social Battery Series
              </p>
              <div class="flex items-start justify-between gap-2 mb-2 min-w-0">
                <h3 class="font-display font-bold leading-snug text-foreground text-sm uppercase tracking-tight text-[0.9rem]">
                  Battery: 3% Tee
                </h3>
                <span class="badge badge-outline shrink-0 text-[9px] font-semibold uppercase tracking-wide">Tees</span>
              </div>
              <p class="text-muted-foreground text-xs leading-relaxed line-clamp-2 flex-1 mb-4">
                Oversized statement tee. Social battery icon at 3% — because some days the signal is just gone.
              </p>
              <span class="button-brand primary text-center text-xs w-full" style="padding: 8px 16px; font-size: 11px;">View Transmissions</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Transmissions",
  "settings": [
    {
      "type": "text",
      "id": "prefix_text",
      "default": "TRANSMISSION_LOG",
      "label": "Prefix Text"
    },
    {
      "type": "text",
      "id": "title",
      "default": "LATEST TRANSMISSIONS",
      "label": "Heading Title"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 3,
      "label": "Product Limit"
    }
  ],
  "presets": [
    {
      "name": "Featured Transmissions"
    }
  ]
}
{% endschema %}
