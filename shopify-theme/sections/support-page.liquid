<section class="support-shell">
  <div class="container">
    <div class="support-hero">
      <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: oklch(var(--primary));">{{ section.settings.kicker }}</p>
      <h1 class="heading-brand text-5xl md:text-7xl mb-4">{{ section.settings.heading }}</h1>
      <p class="support-lede">{{ section.settings.lede }}</p>
    </div>

    <div class="support-content">
      {%- for block in section.blocks -%}
        <article class="account-card" {{ block.shopify_attributes }}>
          <h2 class="heading-brand text-2xl mb-3">{{ block.settings.title }}</h2>
          <div class="text-muted-foreground leading-relaxed">{{ block.settings.text }}</div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Support Page",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "SUPPORT_ARCHIVE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Support"
    },
    {
      "type": "textarea",
      "id": "lede",
      "label": "Intro",
      "default": "Everything you need to know before and after your order."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Content Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Support topic"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add your policy or page content here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Support Page"
    }
  ]
}
{% endschema %}
