<div 
  class="min-h-screen transition-theme"
  style="background-color: oklch(var(--background));"
>
  <!-- Decorative Header Banner -->
  <header
    class="relative overflow-hidden py-14 md:py-20 pattern-mandala border-b"
    style="background-color: oklch(var(--card)); border-color: oklch(var(--border));"
  >
    <!-- Dynamic top neon border in signal mode -->
    <div class="header-neon-bar absolute top-0 left-0 right-0 h-1"></div>

    <div class="relative z-10 container text-center">
      <p class="text-xs font-body font-semibold uppercase tracking-[0.35em] mb-3 text-muted-foreground">
        {{ section.settings.subheading | default: 'Emotional Archive &bull; Signal Series' }}
      </p>

      <h1 
        class="heading-brand text-5xl md:text-7xl mb-4 collection-title"
        style="color: oklch(var(--foreground));"
      >
        {{ collection.title | upcase }}
      </h1>

      <p class="font-body text-sm md:text-base max-w-md mx-auto text-muted-foreground">
        {{ collection.description | default: 'A curated archive of emotional streetwear drops — wear what you feel.' }}
      </p>
    </div>
  </header>

  <!-- Sticky Search + Filters bar -->
  <div 
    class="sticky top-[56px] md:top-[68px] z-20 backdrop-blur-sm border-b transition-theme filter-sticky-bar"
    style="background-color: oklch(var(--background) / 0.94); border-color: oklch(var(--border) / 0.4);"
  >
    <div class="container py-3" style="display: flex; flex-direction: column; gap: 12px; align-items: center;">
      <!-- Search Input -->
      <div class="relative w-full" style="max-w: 400px; display: flex; align-items: center;">
        <span class="absolute left-3 pointer-events-none" style="color: oklch(var(--muted-foreground)); display: flex; align-items: center;">
          {% render 'icon-search', size: 14 %}
        </span>
        <input 
          data-ocid="products.search_input"
          type="text" 
          placeholder="Search products..." 
          class="input-brand"
          style="padding-left: 36px; padding-right: 36px; height: 36px;"
        />
        <button 
          type="button" 
          class="absolute right-3 cursor-pointer"
          style="color: oklch(var(--muted-foreground)); border: none; display: flex; align-items: center;"
          aria-label="Clear search"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>

      <!-- Mood chips filter -->
      <div class="flex gap-2 overflow-x-auto w-full justify-center [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" style="max-width: 600px;">
        <button type="button" class="mood-chip active" data-ocid="products.mood.clear">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          All Moods
        </button>
        {%- assign moods = 'Chaos,Isolation,Obsession,Escape,Overthinking,Burnout' | split: ',' -%}
        {%- for mood in moods -%}
          <button type="button" class="mood-chip" data-ocid="products.mood.{{ mood | downcase }}">
            <span class="inline-block w-2 h-2 rounded-full" style="background-color: oklch(var(--{{ mood | downcase }}));"></span>
            {{ mood }}
          </button>
        {%- endfor -%}
      </div>

      <!-- Category tabs -->
      <div 
        class="flex gap-1.5 overflow-x-auto w-full justify-center [scrollbar-width:none] [&::-webkit-scrollbar]:hidden" 
        data-ocid="products.filter.tab"
        style="max-width: 500px;"
      >
        <button type="button" class="shrink-0 px-4 py-1.5 rounded-full font-body font-semibold text-xs uppercase tracking-wider transition-smooth active" data-ocid="products.category.all" style="background-color: oklch(var(--primary)); color: oklch(var(--primary-foreground));">
          All
        </button>
        {%- assign categories = 'Tees,Hoodies,Shorts,Lowers' | split: ',' -%}
        {%- for cat in categories -%}
          <button type="button" class="shrink-0 px-4 py-1.5 rounded-full font-body font-semibold text-xs uppercase tracking-wider transition-smooth" data-ocid="products.category.{{ cat | downcase }}" style="background-color: oklch(var(--muted)); color: oklch(var(--muted-foreground));">
            {{ cat }}
          </button>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- Main grid listing -->
  <main class="container py-10">
    <div 
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"
      data-ocid="products.list"
    >
      {%- if collection.products_count > 0 -%}
        {%- for product in collection.products -%}
          {% render 'product-card', product: product, index: forloop.index0 %}
        {%- endfor -%}
      {%- else -%}
        {% comment %} Placeholder cards if store empty {% endcomment %}
        {%- assign placeholder_titles = 'Battery: 3% Tee,Recharge Failed Hoodie,Interaction Overload Shorts,Missing Identity Tee' | split: ',' -%}
        {%- assign placeholder_cats = 'Tees,Hoodies,Shorts,Tees' | split: ',' -%}
        {%- assign placeholder_moods = 'obsession,isolation,burnout,burnout' | split: ',' -%}
        {%- assign placeholder_series = 'Social Battery Series,Social Battery Series,Social Battery Series,Memory Corruption Series' | split: ',' -%}
        {%- for title in placeholder_titles -%}
          {%- liquid
            assign idx = forloop.index0
            assign cat = placeholder_cats[idx]
            assign mood = placeholder_moods[idx]
            assign series = placeholder_series[idx]
          -%}
          <div 
            class="card-brand group relative flex flex-col"
            data-product-card
            data-category="{{ cat | downcase }}"
            data-mood="{{ mood | downcase }}"
            data-title="{{ title | downcase }}"
            data-desc=""
            style="animation-delay: {{ idx | multiply: 0.08 }}s;"
          >
            <div class="relative w-full overflow-hidden" style="aspect-ratio: 3/4; background-color: oklch(var(--muted) / 0.15);">
              <a href="#" class="block w-full h-full transition-smooth group-hover:scale-105">
                {% render 'product-mockup', category: cat, series: series, emotion: mood %}
              </a>
              <div class="price-badge absolute top-3 right-3 rounded px-2.5 py-1 font-display text-sm font-bold" style="background-color: oklch(var(--background)); border: 1px solid oklch(var(--border));">
                Rs.2,499
              </div>
              <div class="absolute bottom-3 left-3 px-2 py-0.5 rounded text-[9px] font-bold uppercase tracking-widest" style="background-color: oklch(var(--{{ mood }}))22; color: oklch(var(--{{ mood }})); border: 1px solid oklch(var(--{{ mood }}))44;">
                {{ mood }}
              </div>
            </div>
            <div class="p-4 flex flex-col flex-1" style="border-top: 1px solid oklch(var(--border));">
              <p class="text-[9px] font-semibold uppercase tracking-[0.2em] mb-1.5" style="color: oklch(var(--muted-foreground));">{{ series }}</p>
              <div class="flex items-start justify-between gap-2 mb-2 min-w-0">
                <h3 class="font-display font-bold leading-snug text-foreground text-sm uppercase tracking-tight text-[0.9rem]">
                  {{ title }}
                </h3>
                <span class="badge badge-outline shrink-0 text-[9px] font-semibold uppercase tracking-wide">{{ cat }}</span>
              </div>
              <p class="text-muted-foreground text-xs leading-relaxed line-clamp-2 flex-1 mb-4">
                Gen-Z custom aesthetic design drop. Representing digital emotional cycles.
              </p>
              <span class="button-brand primary text-center text-xs w-full" style="padding: 8px 16px; font-size: 11px;">View Transmissions</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <!-- Empty State -->
    <div 
      key="empty"
      style="display: none; flex-direction: column; align-items: center; justify-content: center; padding: 96px 0;"
      class="text-center"
      data-ocid="products.empty_state"
    >
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity: 0.3; margin-bottom: 20px;"><circle cx="12" cy="12" r="10"></circle><line x1="8" y1="12" x2="16" y2="12"></line></svg>
      <p class="font-display text-2xl font-bold uppercase mb-2" style="color: oklch(var(--foreground));">No matches found</p>
      <p class="font-body text-sm mb-6 text-muted-foreground">Nothing aligns with this query — try adjusting your filter matrix.</p>
    </div>
  </main>

  <!-- Cultural Band Footer Accent -->
  <div 
    class="py-8 mt-4 pattern-block-print border-t"
    style="background-color: oklch(var(--card) / 0.5); border-color: oklch(var(--border));"
  >
    <div class="container text-center">
      <p class="heading-brand text-xs md:text-sm tracking-[0.25em]" style="color: oklch(var(--primary));">
        ⚡ WEAR THE SIGNAL — FIVE SERIES &bull; ZERO LIMITS ⚡
      </p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "default": "Emotional Archive &bull; Signal Series",
      "label": "Subheading Banner Text"
    }
  ]
}
{% endschema %}
