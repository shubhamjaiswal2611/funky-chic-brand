<section class="support-shell">
  <div class="container">
    <div class="support-hero">
      <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: oklch(var(--primary));">SEARCH_SIGNAL</p>
      <h1 class="heading-brand text-5xl md:text-7xl mb-4">Search</h1>
      <form action="{{ routes.search_url }}" method="get" role="search" class="search-bar">
        <input class="input-brand" type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search drops, pages, archives">
        <button class="button-brand primary" type="submit">Search</button>
      </form>
    </div>

    {%- if search.performed -%}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {%- if search.results_count > 0 -%}
          {%- for item in search.results -%}
            <article class="account-card">
              <p class="font-mono text-[10px] uppercase tracking-widest mb-2 text-muted-foreground">{{ item.object_type }}</p>
              <h2 class="heading-brand text-xl mb-3"><a href="{{ item.url }}">{{ item.title }}</a></h2>
              <p class="text-muted-foreground">{{ item.content | strip_html | truncate: 130 }}</p>
            </article>
          {%- endfor -%}
        {%- else -%}
          <div class="account-empty">
            <p class="heading-brand text-xl mb-2">No matches found</p>
            <p class="text-muted-foreground">Try another signal.</p>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Search",
  "settings": []
}
{% endschema %}
