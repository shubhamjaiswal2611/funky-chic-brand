<section class="account-shell pattern-grid">
  <div class="container account-wrap account-wrap-single">
    <div class="account-panel">
      <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: oklch(var(--primary));">RESET_ACCESS</p>
      <h1 class="heading-brand text-5xl mb-4">Reset Password</h1>
      <p class="text-muted-foreground mb-8">Create a new key for your account archive.</p>

      {%- form 'reset_customer_password', class: 'account-form' -%}
        {%- if form.errors -%}
          <div class="form-alert">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <label class="form-label" for="ResetPassword">New password</label>
        <input id="ResetPassword" class="input-brand" type="password" name="customer[password]" autocomplete="new-password" required>
        <label class="form-label" for="ResetPasswordConfirmation">Confirm password</label>
        <input id="ResetPasswordConfirmation" class="input-brand" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
        <button class="button-brand primary w-full" type="submit">Update Password</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reset Password",
  "settings": []
}
{% endschema %}
