<section 
  data-ocid="home.lore_countdown_section"
  class="py-20"
  style="background-color: oklch(var(--background)); border-bottom: 1px solid oklch(var(--border));"
>
  <div class="container">
    <!-- Headers -->
    <div class="text-center mb-12">
      <p class="font-mono text-xs uppercase tracking-[0.2em] mb-3" style="color: oklch(var(--primary));">
        {{ section.settings.prefix_text }}
      </p>
      <h2 
        class="font-display font-black uppercase text-foreground"
        style="font-size: clamp(1.8rem, 5vw, 3rem); letter-spacing: -0.02em;"
      >
        {{ section.settings.title }}
      </h2>
      {%- if section.settings.description != blank -%}
        <p class="font-body text-sm mt-3 max-w-md mx-auto" style="color: oklch(var(--muted-foreground));">
          {{ section.settings.description }}
        </p>
      {%- endif -%}
    </div>

    <!-- Live Timer Wrapper -->
    <div 
      data-countdown-target="{{ section.settings.target_timestamp }}"
      class="flex flex-wrap justify-center gap-4 md:gap-6"
    >
      <!-- Active state: Count units -->
      <div data-countdown="active" class="flex flex-wrap justify-center gap-4 md:gap-6">
        <div class="countdown-container" data-ocid="home.countdown.item.1">
          <span class="countdown-digit" data-countdown="days">00</span>
          <span class="countdown-label">Days</span>
        </div>
        <div class="countdown-container" data-ocid="home.countdown.item.2">
          <span class="countdown-digit" data-countdown="hours">00</span>
          <span class="countdown-label">Hours</span>
        </div>
        <div class="countdown-container" data-ocid="home.countdown.item.3">
          <span class="countdown-digit" data-countdown="minutes">00</span>
          <span class="countdown-label">Minutes</span>
        </div>
        <div class="countdown-container" data-ocid="home.countdown.item.4">
          <span class="countdown-digit" data-countdown="seconds">00</span>
          <span class="countdown-label">Seconds</span>
        </div>
      </div>

      <!-- Zero state / Finished countdown -->
      <div 
        data-countdown="zerostate" 
        style="display: none;" 
        class="text-center" 
        data-ocid="home.countdown.zero_state"
      >
        <span 
          class="font-display font-black uppercase text-2xl md:text-4xl"
          style="color: oklch(var(--secondary)); text-shadow: 0 0 20px oklch(var(--secondary) / 0.4);"
        >
          {{ section.settings.completion_message }}
        </span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lore Countdown",
  "settings": [
    {
      "type": "text",
      "id": "prefix_text",
      "default": "INCOMING_SIGNAL",
      "label": "Prefix Label"
    },
    {
      "type": "text",
      "id": "title",
      "default": "SIGNAL INCOMING",
      "label": "Heading Title"
    },
    {
      "type": "textarea",
      "id": "description",
      "default": "A new chapter is loading. Stay tuned for the lore drop.",
      "label": "Description text"
    },
    {
      "type": "text",
      "id": "target_timestamp",
      "default": "2026-10-31T00:00:00",
      "label": "Target Timestamp (ISO 8601)",
      "info": "Format: YYYY-MM-DDTHH:MM:SS (e.g. 2026-12-25T18:00:00)"
    },
    {
      "type": "text",
      "id": "completion_message",
      "default": "⚡ SIGNAL DETECTED — ARCHIVE OPENED ⚡",
      "label": "Completion Message"
    }
  ],
  "presets": [
    {
      "name": "Lore Countdown"
    }
  ]
}
{% endschema %}
