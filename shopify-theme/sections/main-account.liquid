<section class="account-shell">
  <div class="container">
    <div class="account-header">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: oklch(var(--primary));">CUSTOMER_ARCHIVE</p>
        <h1 class="heading-brand text-5xl">Account</h1>
        <p class="text-muted-foreground mt-3">{{ customer.name | default: customer.email }}</p>
      </div>
      <div class="flex flex-wrap gap-3">
        <a href="{{ routes.account_addresses_url }}" class="button-brand secondary">Addresses</a>
        <a href="{{ routes.account_logout_url }}" class="button-brand secondary">Logout</a>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-10">
      <div class="lg:col-span-2">
        <h2 class="heading-brand text-2xl mb-4">Orders</h2>
        {%- paginate customer.orders by 12 -%}
          {%- if customer.orders.size > 0 -%}
            <div class="account-table-wrap">
              <table class="account-table">
                <thead>
                  <tr>
                    <th>Order</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Total</th>
                  </tr>
                </thead>
                <tbody>
                  {%- for order in customer.orders -%}
                    <tr>
                      <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                      <td>{{ order.created_at | date: "%b %d, %Y" }}</td>
                      <td>{{ order.fulfillment_status_label }}</td>
                      <td>{{ order.total_price | money }}</td>
                    </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            </div>
          {%- else -%}
            <div class="account-empty">
              <p class="heading-brand text-xl mb-2">No orders yet</p>
              <p class="text-muted-foreground mb-6">Your first transmission will appear here after checkout.</p>
              <a href="{{ routes.all_products_collection_url }}" class="button-brand primary">Shop Drops</a>
            </div>
          {%- endif -%}

          {%- if paginate.pages > 1 -%}
            <div class="account-pagination">
              {{ paginate | default_pagination }}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      </div>

      <aside class="account-card">
        <h2 class="heading-brand text-2xl mb-4">Default Address</h2>
        {%- if customer.default_address -%}
          <div class="text-muted-foreground leading-relaxed">{{ customer.default_address | format_address }}</div>
        {%- else -%}
          <p class="text-muted-foreground">No saved address yet.</p>
        {%- endif -%}
        <a href="{{ routes.account_addresses_url }}" class="button-brand secondary mt-6">Manage Addresses</a>
        <a href="/pages/track-order" class="button-brand primary mt-4">Track Order</a>
      </aside>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer Account",
  "settings": []
}
{% endschema %}
