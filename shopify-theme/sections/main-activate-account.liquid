<section class="account-shell pattern-grid">
  <div class="container account-wrap account-wrap-single">
    <div class="account-panel">
      <p class="font-mono text-xs uppercase tracking-widest mb-3" style="color: oklch(var(--primary));">ACTIVATE_PROFILE</p>
      <h1 class="heading-brand text-5xl mb-4">Activate Account</h1>
      <p class="text-muted-foreground mb-8">Set your password to unlock your customer archive.</p>

      {%- form 'activate_customer_password', class: 'account-form' -%}
        {%- if form.errors -%}
          <div class="form-alert">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <label class="form-label" for="ActivatePassword">Password</label>
        <input id="ActivatePassword" class="input-brand" type="password" name="customer[password]" autocomplete="new-password" required>
        <label class="form-label" for="ActivatePasswordConfirmation">Confirm password</label>
        <input id="ActivatePasswordConfirmation" class="input-brand" type="password" name="customer[password_confirmation]" autocomplete="new-password" required>
        <div class="flex flex-wrap gap-3">
          <button class="button-brand primary" type="submit">Activate</button>
          <button class="button-brand secondary" type="submit" name="decline">Decline</button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Activate Account",
  "settings": []
}
{% endschema %}
